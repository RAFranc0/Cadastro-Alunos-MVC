@model CadastroAlunosMVC.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout"; // Mantém o menu superior, se desejar
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg p-4" style="width: 100%; height: 500px; max-width: 400px; border-radius: 15px;">
        <div class="text-center mb-1">
            <i class="bi bi-shield-lock-fill text-primary" style="font-size: 3rem;"></i>
            <h2 class="fw-bold">Acesso ao Sistema</h2>
            <p class="text-muted">Entre com suas credenciais</p>
        </div>
        
        <!-- ###################################### -->
        <!-- ########## Form de Login ########## -->
        <!-- ###################################### -->
        <form asp-action="Login" method="post">
            <div class="mb-1" style="height: 40px">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("LoginErro"))
                {
                    <span class="alert alert-danger d-block p-2 small h-100">
                        @ViewData.ModelState["LoginErro"].Errors.FirstOrDefault()?.ErrorMessage
                    </span>
                }
            </div>
            

            <div class="mb-3">
                <label asp-for="Usuario" class="form-label">Usuário</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="Usuario" class="form-control" placeholder="Ex: admin" required/>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Senha" class="form-label">Senha</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                    <input asp-for="Senha" type="password" class="form-control" placeholder="••••••" required/>
                </div>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="LembrarMe" class="form-check-input"/>
                <label asp-for="LembrarMe" class="form-check-label">Lembrar de mim</label>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary btn-lg">Entrar</button>
            </div>
        </form>
    </div>
    
    <div class="card shadow-lg p-4" style="width: 400px; height: 500px; max-width: 400px; border-radius: 15px;">
        <div class="text-center mb-2">
            <i class="bi bi-shield-lock-fill text-primary" style="font-size: 3rem;"></i>
            <h2 class="fw-bold">Faça seu cadastro</h2>
            <p class="text-muted">Digite os dados abaixo:</p>
        </div>
        
        <!-- ###################################### -->
        <!-- ########## Form de Cadastro ########## -->
        <!-- ###################################### -->
        
        <form asp-action="Create" asp-controller="Account" method="post">
            <div class="mb-1" style="height: 40px">
                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey("CadastroErro"))
                {
                    <span class="alert alert-danger d-block p-2 small h-100">
                        @ViewData.ModelState["CadastroErro"].Errors.FirstOrDefault()?.ErrorMessage
                    </span>
                }
            </div>

            <div class="mb-3">
                <label asp-for="User.Usuario" class="form-label">Usuário</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="User.Usuario" class="form-control" placeholder="Ex: admin" required/>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="User.Senha" class="form-label">Senha</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                    <input asp-for="User.Senha" type="password" class="form-control" placeholder="••••••" required/>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-warning btn-lg">Cadastrar</button>
            </div>
        </form>
    </div>
</div>